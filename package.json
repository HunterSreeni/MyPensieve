{
  "name": "mypensieve",
  "version": "0.1.0",
  "description": "A general-purpose, self-evolving autonomous agent OS with persistent memory across sessions",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mypensieve": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "check": "biome check src/ tests/ && tsc --noEmit && vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "better-sqlite3": "^11.7.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "agent",
    "ai",
    "memory",
    "autonomous",
    "pi-coding-agent"
  ],
  "license": "MIT"
}
