{
  "name": "mypensieve",
  "version": "0.3.6",
  "description": "A general-purpose, self-evolving autonomous agent OS with persistent memory across sessions",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mypensieve": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3 2>/dev/null || true",
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "check": "biome check src/ tests/ && tsc --noEmit && vitest run",
    "version": "bash scripts/on-version.sh",
    "prepublishOnly": "npm run check && npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HunterSreeni/MyPensieve.git"
  },
  "bugs": {
    "url": "https://github.com/HunterSreeni/MyPensieve/issues"
  },
  "homepage": "https://github.com/HunterSreeni/MyPensieve#readme",
  "author": "Sreenivasan S (Sreeni)",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "@mariozechner/pi-ai": "0.67.3",
    "@mariozechner/pi-coding-agent": "0.67.3",
    "better-sqlite3": "11.10.0",
    "cron": "4.4.0",
    "grammy": "1.42.0",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "overrides": {
    "basic-ftp": "5.3.0",
    "protobufjs": "7.5.5"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cron": "^2.0.1",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --apply --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ],
    "tests/**/*.ts": [
      "biome check --apply --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "agent",
    "ai",
    "memory",
    "autonomous",
    "pensieve",
    "pi-coding-agent",
    "llm",
    "cli",
    "telegram"
  ]
}
